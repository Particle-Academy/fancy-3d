{
  "name": "@particle-academy/fancy-3d",
  "version": "0.4.1",
  "description": "Engine-agnostic 3D core for Particle Academy — Scene types, the <Canvas> surface, and a DOM/CSS-3D renderer. WebGL renderers (Babylon, three.js, …) ship as separate `@particle-academy/fancy-3d-<engine>` packages.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-3d.git"
  },
  "homepage": "https://github.com/Particle-Academy/fancy-3d#readme",
  "bugs": "https://github.com/Particle-Academy/fancy-3d/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./dom": {
      "import": {
        "types": "./dist/dom.d.ts",
        "default": "./dist/dom.js"
      },
      "require": {
        "types": "./dist/dom.d.cts",
        "default": "./dist/dom.cjs"
      }
    },
    "./canvas": {
      "import": {
        "types": "./dist/canvas/index.d.ts",
        "default": "./dist/canvas/index.js"
      },
      "require": {
        "types": "./dist/canvas/index.d.cts",
        "default": "./dist/canvas/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "react",
    "3d",
    "scene",
    "ui",
    "spatial",
    "engine-agnostic"
  ],
  "peerDependencies": {
    "@particle-academy/react-fancy": ">=3",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@particle-academy/react-fancy": {
      "optional": true
    }
  },
  "devDependencies": {
    "@particle-academy/react-fancy": "^3.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
